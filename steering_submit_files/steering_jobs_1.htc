universe = vanilla
executable = steering_submit_files/run_steering.sh
request_cpus = 8
request_gpus = 1
request_memory = 16000
getenv = True
log = steering_logs/job_$(Cluster)_$(Process).log
output = steering_logs/job_$(Cluster)_$(Process).out
error = steering_logs/job_$(Cluster)_$(Process).err
arguments = "--model Qwen/Qwen2.5-7B-Instruct --technique dom --layer_pct 25 --output_csv C:\Users\fonta\Desktop\brainrot\steering_results\Qwen7B_dom_L25.csv --device cuda --max_pairs 2000 --coefficients 5,10,25,-5,-10,-25 --hf_cache_dir /scratch/huggingface_cache"
queue
