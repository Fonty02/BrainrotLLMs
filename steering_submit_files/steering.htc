universe = vanilla
executable = steering_submit_files/run_steering.sh
request_cpus = 8
request_gpus = 1
request_memory = 16000
getenv=True
log = steering_logs/job_$(Cluster)_$(Process).log
output = steering_logs/job_$(Cluster)_$(Process).out
error = steering_logs/job_$(Cluster)_$(Process).err
arguments = "$(MODEL) $(TECHNIQUE) $(LAYER_PCT)"
queue MODEL, TECHNIQUE, LAYER_PCT from (
  Qwen/Qwen2.5-7B-Instruct aas 25
  Qwen/Qwen2.5-7B-Instruct aas 50
  Qwen/Qwen2.5-7B-Instruct aas 75
)
