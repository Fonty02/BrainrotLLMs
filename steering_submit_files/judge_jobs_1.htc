universe = vanilla
executable = steering_submit_files/run_judge.sh
request_cpus = 8
request_gpus = 1
request_memory = 8900
getenv = True
log = steering_logs/judge_$(Cluster)_$(Process).log
output = steering_logs/judge_$(Cluster)_$(Process).out
error = steering_logs/judge_$(Cluster)_$(Process).err
arguments = "--input_csv steering_results/gemma-4-E2B-it_aas_L25.csv --output_csv steering_results/gemma-4-E2B-it_aas_L25_judged.csv --model_id google/gemma-4-E4B-it --judge_type brainrot --batch_size 16 --hf_cache_dir /lustrehome/fonty/huggingface_cache"
queue
arguments = "--input_csv steering_results/gemma-4-E2B-it_aas_L50.csv --output_csv steering_results/gemma-4-E2B-it_aas_L50_judged.csv --model_id google/gemma-4-E4B-it --judge_type brainrot --batch_size 16 --hf_cache_dir /lustrehome/fonty/huggingface_cache"
