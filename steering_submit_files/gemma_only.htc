universe = vanilla
executable = steering_submit_files/run_steering.sh
request_cpus = 8
request_gpus = 1
request_memory = 16000
getenv = True
log = steering_logs/job_$(Cluster)_$(Process).log
output = steering_logs/job_$(Cluster)_$(Process).out
error = steering_logs/job_$(Cluster)_$(Process).err

arguments = "--model google/gemma-4-E2B-it --technique dom --layer_pct 25 --output_csv /lustrehome/fonty/CliCIT2026/BrainrotLLMs/steering_results/Gemma2B_dom_L25.csv --device cuda --max_pairs 2000 --coefficients 5,10,25,-5,-10,-25 --hf_cache_dir /lustrehome/fonty/huggingface_cache"
queue
arguments = "--model google/gemma-4-E2B-it --technique dom --layer_pct 50 --output_csv /lustrehome/fonty/CliCIT2026/BrainrotLLMs/steering_results/Gemma2B_dom_L50.csv --device cuda --max_pairs 2000 --coefficients 5,10,25,-5,-10,-25 --hf_cache_dir /lustrehome/fonty/huggingface_cache"
queue
